@startuml parser_main
!pragma teoz true
hide footbox
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 80
skinparam style strictuml
skinparam SequenceGroupBodyBackgroundColor transparent
skinparam SequenceReferenceBackgroundColor white
skinparam sequenceArrowThickness 1.5
skinparam roundcorner 5
skinparam SequenceBoxBackgroundColor transparent
skinparam sequenceParticipantBackgroundColor white
skinparam sequenceLifeLineBorderColor black

participant ":FlashCLI" as FlashCLI
participant ":Parser" as Parser
participant ":ArgumentExtractor" as ArgumentExtractor

FlashCLI -> Parser : parse(userInput)
activate Parser

Parser -> Parser : validateInput(userInput)
activate Parser
deactivate Parser

Parser -> Parser : validateCommandName(command)
activate Parser
deactivate Parser

|||

alt invalid input or unknown command
    Parser --> FlashCLI : throws FlashException
else valid command
    ref over Parser, ArgumentExtractor
        dispatch
    end ref

    Parser --> FlashCLI : Command
end

deactivate Parser
@enduml