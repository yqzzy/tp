@startuml
hide footbox
skinparam sequenceArrowFontSize 11
skinparam sequenceParticipantFontSize 12
skinparam defaultFontSize 12

participant ":SessionManager" as sm
participant ":StudySession" as ss
participant "deck : Deck" as deck
participant "tempCards : ArrayList<Card>" as tempCards
participant "tempDeck : Deck" as tempDeck

activate sm
sm -> sm : startSession(deck)

create ss
sm -> ss : new StudySession(deck)
activate ss

ss -> deck : listCards()
activate deck
deck --> ss : ArrayList<Card>
deactivate deck

ss -> tempCards : new ArrayList<>(cards)
activate tempCards
deactivate tempCards

ss -> tempCards : sort(Comparator.comparing(Card::getConfidenceLevel))
activate tempCards
deactivate tempCards

create tempDeck
ss -> tempDeck : new Deck(deck.getDeckName())
activate tempDeck
tempDeck --> ss : tempDeck
deactivate tempDeck

ss -> tempDeck : setCards(tempCards)
activate tempDeck
deactivate tempDeck

note over ss
this.deck = tempDeck
currentIndex = 0
assert currentIndex == 0
end note

ss --> sm : StudySession ready
deactivate ss

note over sm
assert hasActiveSession()
assert activeSession.getDeckName()
  .equals(deck.getDeckName())
end note

deactivate sm
@enduml
