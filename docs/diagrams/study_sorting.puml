@startuml
skinparam sequenceArrowFontSize 11
skinparam sequenceParticipantFontSize 12
skinparam defaultFontSize 12

participant ":SessionManager" as sm
participant ":StudySession" as ss
participant "tempCards : ArrayList<Card>" as list
participant "tempDeck : Deck" as tempDeck

note over sm : startSession(deck) called

sm -> ss : new StudySession(deck)
activate ss

ss -> list : deck.listCards()
list --> ss : ArrayList<Card>

ss -> list : sort by getConfidenceLevel()\n(ascending)
note right of list
  Cards with lowest confidence
  level appear first.
  Default confidence = 0.
end note

ss -> tempDeck : new Deck(deck.getDeckName())
ss -> tempDeck : setCards(sortedCards)

note over ss
  this.deck = tempDeck
  currentIndex = 0
  assert currentIndex == 0
end note

ss --> sm : StudySession ready
deactivate ss

note over sm
  assert hasActiveSession()
  assert session.getDeckName()
    .equals(deck.getDeckName())
end note
@enduml
